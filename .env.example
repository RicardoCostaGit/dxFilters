# Copy to .env in the repo root (optional — the menu bar app saves credentials separately).
# Replace <BASE_URL> with your Jira host, no trailing slash.

JIRA_BASE_URL=https://<BASE_URL>
JIRA_FILTER_ID=12345

# --- Pick ONE authentication style ---

# Jira Cloud: email + API token
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your_atlassian_api_token

# Jira Server / Data Center: Personal Access Token
JIRA_PAT=

# Optional: poll interval for CLI --loop (seconds)
# POLL_INTERVAL_SECONDS=300
